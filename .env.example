# Copier ce fichier en .env et remplir les valeurs réelles
# Ne jamais commiter .env dans Git

# ── PostgreSQL ─────────────────────────────────────────────────────────────
# Nom de la base de données utilisée par l'application
POSTGRES_DB=vytalsync

# Utilisateur PostgreSQL (propriétaire de la base)
POSTGRES_USER=vytalsync_user

# Mot de passe PostgreSQL – utiliser une valeur forte en production
POSTGRES_PASSWORD=changeme

# ── Backend ────────────────────────────────────────────────────────────────
# Port d'écoute du serveur Node.js
PORT=3000

# Environnement d'exécution : development | test | production
NODE_ENV=production

# URL de connexion à la base (construite à partir des variables ci-dessus)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}
